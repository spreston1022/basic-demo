{
  "info": {
    "title": "Echo API",
    "version": "1.0.0",
    "description": "A simple echo endpoint used for testing and demonstration purposes.\nReturns the full request details including headers, query parameters, and body.\nHosted at echo.zuplo.io — commonly used as a mock backend in Zuplo gateway demos.\n"
  },
  "openapi": "3.1.0",
  "components": {
    "schemas": {
      "EchoResponse": {
        "type": "object",
        "description": "Full echo of the incoming request",
        "properties": {
          "method": {
            "type": "string",
            "description": "HTTP method of the request",
            "example": "GET"
          },
          "url": {
            "type": "string",
            "description": "Full URL of the request",
            "example": "https://echo.zuplo.io/path-10"
          },
          "headers": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "All request headers as key-value pairs",
            "example": {
              "authorization": "Bearer zpka_abc123",
              "content-type": "application/json"
            }
          },
          "query": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Query string parameters as key-value pairs",
            "example": {
              "foo": "bar"
            }
          },
          "body": {
            "description": "Request body — null for GET requests",
            "nullable": true,
            "type": "null"
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "OAuth Bearer JWT — must contain a 'sid' claim"
      }
    }
  },
  "servers": [
    {
      "url": "https://echo.zuplo.io",
      "description": "Zuplo echo service"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/auth": {
      "x-zuplo-path": {
        "pathMode": "open-api"
      },
      "post": {
        "summary": "Authentication endpoint",
        "description": "Sliding-window rate limited to 60 req/min per IP. Add `?bypass` to skip the rate limit. Requires a Bearer JWT with a `sid` claim; caps total active sessions at 3.",
        "operationId": "auth-post",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Echo response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EchoResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid Bearer token"
          },
          "429": {
            "description": "Rate limit exceeded (60 req/min) or session cap reached"
          }
        },
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://echo.zuplo.io"
            }
          },
          "policies": {
            "inbound": ["auth-rate-limit", "session-cap"]
          }
        }
      }
    },
    "/profile": {
      "x-zuplo-path": {
        "pathMode": "open-api"
      },
      "get": {
        "summary": "Get user profile",
        "description": "Protected endpoint. Session cap enforced — same 3-session limit shared across all endpoints.",
        "operationId": "profile-get",
        "responses": {
          "200": { "description": "Echo response" },
          "401": { "description": "Missing or invalid Bearer token" },
          "503": { "description": "Session cap reached" }
        },
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": { "baseUrl": "https://echo.zuplo.io" }
          },
          "policies": { "inbound": ["session-cap"] }
        }
      }
    },
    "/orders": {
      "x-zuplo-path": {
        "pathMode": "open-api"
      },
      "get": {
        "summary": "List orders",
        "description": "Protected endpoint. Session cap enforced — same 3-session limit shared across all endpoints.",
        "operationId": "orders-get",
        "responses": {
          "200": { "description": "Echo response" },
          "401": { "description": "Missing or invalid Bearer token" },
          "503": { "description": "Session cap reached" }
        },
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": { "baseUrl": "https://echo.zuplo.io" }
          },
          "policies": { "inbound": ["session-cap"] }
        }
      }
    },
    "/path-11": {
      "x-zuplo-path": {
        "pathMode": "open-api"
      },
      "get": {
        "summary": "Echo a GET request",
        "description": "Returns the full details of the incoming GET request as JSON — headers, query parameters, URL, and method. Requires a Bearer JWT with a `sid` claim; caps total active sessions at 3.",
        "operationId": "echo-get",
        "parameters": [
          {
            "name": "any",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Any query parameters are echoed back in the response"
          }
        ],
        "responses": {
          "200": {
            "description": "Echo response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EchoResponse"
                },
                "example": {
                  "method": "GET",
                  "url": "https://echo.zuplo.io/path-10?foo=bar",
                  "headers": {
                    "authorization": "Bearer <jwt>",
                    "user-agent": "curl/7.88.1",
                    "accept": "*/*"
                  },
                  "query": {
                    "foo": "bar"
                  },
                  "body": null
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid Bearer token"
          },
          "503": {
            "description": "Session cap reached"
          }
        },
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://echo.zuplo.io"
            }
          },
          "policies": {
            "inbound": ["session-cap"]
          }
        }
      }
    }
  }
}
